    "@react-email/render": "^2.0.6",
    "@scalar/hono-api-reference": "^0.10.7",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.6.2",
    "hono": "^4.12.12",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3",
    "resend": "^6.10.0",
    "slugify": "^1.6.9",
