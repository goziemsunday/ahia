{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ES2023",
    "module": "commonjs",
    // "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/migrate.ts"]
}
