{
  "name": "@repo/db",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "default": "./dist/schemas/*.js"
    },
    "./validators/*": {
      "types": "./dist/validators/*.d.ts",
      "default": "./dist/validators/*.js"
    }
  },
  "scripts": {
    "build": "bunx tsc",
    "db:delete": "docker compose down -v",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate --config=drizzle.config.mts",
    "db:migrate": "drizzle-kit migrate",
    "db:psql": "docker exec -it ahia-pg psql -U user -d ahia",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
